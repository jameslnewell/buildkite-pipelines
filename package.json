{
  "name": "buildkite-pipelines-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @jameslnewell/buildkite-pipelines and related packages.",
  "author": "James Newell <gday@jameslnewell.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jameslnewell/buildkite-pipelines.git"
  },
  "bugs": {
    "url": "https://github.com/jameslnewell/buildkite-pipelines/issues"
  },
  "homepage": "https://github.com/jameslnewell/buildkite-pipelines",
  "packageManager": "pnpm@8.6.6",
  "scripts": {
    "prepare": "husky && pnpm -r run codegen",
    "codegen": "pnpm -r run codegen",
    "develop": "pnpm -r run develop",
    "build": "pnpm -r run build",
    "build:types": "pnpm -r run build:types",
    "build:transpile": "pnpm -r run build:transpile",
    "build:pages": "pnpm -r run build:pages",
    "check": "pnpm -r run check",
    "check:formatting": "pnpm -r run check:formatting",
    "check:typing": "pnpm -r run check:typing",
    "fix:formatting": "pnpm -r run fix:formatting",
    "fix:formatting:staged": "pnpm -r exec pretty-quick --staged",
    "test": "pnpm -r run test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7"
  }
}
